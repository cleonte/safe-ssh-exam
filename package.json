{
  "name": "secure-exam-terminal",
  "version": "1.0.0",
  "description": "A secure, locked-down terminal/SSH client for exam environments",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "tsc",
    "prebuild": "npm run build:ts",
    "prestart": "npm run build:ts",
    "predev": "npm run build:ts",
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "npm run build:ts && electron-builder",
    "build:mac": "npm run build:ts && electron-builder --mac",
    "build:win": "npm run build:ts && electron-builder --win",
    "build:linux": "npm run build:ts && electron-builder --linux",
    "watch": "tsc --watch"
  },
  "keywords": [
    "terminal",
    "ssh",
    "exam",
    "secure",
    "lockdown"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ssh2": "^1.15.0",
    "xterm": "^5.3.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/ssh2": "^1.15.5",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.secureexam.terminal",
    "productName": "SecureExamTerminal",
    "files": [
      "dist/**/*",
      "src/index.html",
      "src/styles.css"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education"
    }
  }
}
